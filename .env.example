# Life360 MCP Server - Environment Configuration
# Copy this file to .env and uncomment the variables you need
# cp .env.example .env

# =============================================================================
# Authentication - RECOMMENDED: Username/Password (OAuth)
# =============================================================================
# This performs OAuth login and gets a fresh API token

LIFE360_USERNAME=your_email@example.com
LIFE360_PASSWORD=your_password
# LIFE360_CLIENT_ID=life360_mobile_app  # optional

# =============================================================================
# Alternative: Authorization Token (May not work due to Cloudflare restrictions)
# =============================================================================
# The token from Life360 app Settings > Account may be blocked by Cloudflare
# Get this from Life360 app: Settings > Account > Authorization Token
# LIFE360_AUTHORIZATION=your_token_here
# LIFE360_TOKEN_TYPE=Bearer  # optional

# =============================================================================
# Optional Settings
# =============================================================================

# LIFE360_CACHE_TTL=30          # Cache TTL in seconds (default: 30)
# LIFE360_MAX_RETRIES=5         # Max retries on 429/5xx errors (default: 5)
# LIFE360_LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR (default: INFO)
# LIFE360_HTTP_HOST=127.0.0.1   # HTTP server bind host (default: 127.0.0.1)
# LIFE360_HTTP_PORT=8123         # HTTP server port (default: 8123)